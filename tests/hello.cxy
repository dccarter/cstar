struct Greet[T] {
    func hello[U](id: T, name: U) {
    }

    func say(id: T, name: string) => hello(id, name)
}

func println(...args: auto) {
    #const i = 0;
    #for (const arg: #{args.Tinfo}) {
        args.#{i};
        #{i += 1}
    }
}

